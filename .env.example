# =============================================================================
# SUPABASE - Backend e Banco de Dados
# =============================================================================

# Supabase Configuration
# Obtenha esses valores em https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

# CLI/MCP (para comandos e automacao)
SUPABASE_PROJECT_REF=
SUPABASE_ACCESS_TOKEN=

# Frontend (Vite) - obtenha no dashboard Settings > API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database
# String de conexao PostgreSQL (para migrations locais)
# Formato: postgresql://user:password@host:port/database
DATABASE_URL=

# =============================================================================
# TELEGRAM - Notificacoes
# =============================================================================

# Telegram Bot Token
# Obtenha criando um bot via @BotFather no Telegram
TELEGRAM_BOT_TOKEN=

# Telegram Chat ID (seu ID pessoal para testes)
# Obtenha enviando /start para @userinfobot no Telegram
TELEGRAM_CHAT_ID=

# =============================================================================
# STRIPE - Pagamentos e Assinaturas
# =============================================================================

# Stripe Configuration
# Obtenha essas chaves em https://dashboard.stripe.com/test/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=

# Stripe Price IDs
# Crie os produtos e precos no Stripe Dashboard e copie os IDs
VITE_STRIPE_PRICE_PRO_MONTHLY=
VITE_STRIPE_PRICE_PRO_YEARLY=
VITE_STRIPE_PRICE_LIFETIME=

# Stripe Webhook Secret (server-side only)
STRIPE_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=

# =============================================================================
# SERVICOS EXTERNOS
# =============================================================================

# Resend - Email Service (para convites de colaboracao)
RESEND_API_KEY=

# OpenRouter API Key (para IA)
OPENROUTER_API_KEY=

# =============================================================================
# OPCIONAL - Analytics
# =============================================================================

# Google Analytics 4
VITE_GA_ID=

# =============================================================================
# OPCIONAL - Desenvolvimento e Debug
# =============================================================================

# App URL (ex.: http://localhost:5173 ou https://seudominio.com)
VITE_APP_URL=

# Hook runtime auth (opt-in)
# false/empty: modo local sem login obrigatorio (padrao recomendado)
# true: exige login no runtime hook
VITE_HOOK_REQUIRE_AUTH=false

# Plan-live review target
# auto (padrao): testa health remoto; se OK usa producao, se falhar usa localhost
# remote: forca revisao na app web (producao)
# local: forca servidor localhost temporario (modo legado)
OBSREVIEW_REVIEW_TARGET=auto

# URL da aplicacao web usada no modo remote
OBSREVIEW_REVIEW_APP_URL=https://r.alexdonega.com.br

# Fallback para localhost quando remote falhar na inicializacao
OBSREVIEW_REMOTE_FALLBACK_LOCAL=true

# Timeout (ms) para probe de health remoto no modo auto
OBSREVIEW_REMOTE_HEALTH_TIMEOUT_MS=2000

# Feature flags (cloud workspace rollout)
VITE_FEATURE_CLOUD_WORKSPACE=true
VITE_FEATURE_RAYCAST_DOCUMENTS=true
VITE_FEATURE_LIVE_PRESENCE=true
VITE_FEATURE_LEGACY_SHARE_READONLY=true

# Allowed CORS origins (comma-separated, for edge functions)
ALLOWED_ORIGINS=

# Codecov token (CI only)
CODECOV_TOKEN=
